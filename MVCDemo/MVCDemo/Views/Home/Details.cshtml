@model MVCDemo.Models.Employee;
@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<h1>@Model.empname</h1>
<div>
    <img src="@Model.imageurl" alt="@Model>empname" width="300" height="300" />
</div>

<div>
    <h2>Employee Details</h2>
    <p>
        Hello, my name is Mohit Chaudhary. I’m currently pursuing my Bachelor’s in Computer Science from Chandigarh University.

        I have a strong interest in full-stack development and problem-solving. I’ve worked on a MERN stack expense tracker application where I implemented JWT-based authentication, protected routes, and filtering logic using MongoDB.

        Along with development, I’ve also explored machine learning projects such as real-time face mask detection using CNN and a thyroid disease prediction model using SVM.

        My core skills include React, JavaScript, C#, SQL, and Python. I’m eager to apply my knowledge in a real-world environment, learn from experienced developers, and contribute effectively as an intern.
    </p>
    <h2>@Model.salary</h2>
    <h2><a asp-action="collectionofobjectpassing">Previous</a></h2>
</div>