<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | UniTrack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Fraunces:wght@700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar">
        <a class="nav-brand" asp-controller="Enrollment" asp-action="Index">
            🎓 <span>UniTrack</span>
        </a>
        <div class="nav-links">
            <a asp-controller="Enrollment" asp-action="Index">Dashboard</a>
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <p>UniTrack &copy; @DateTime.Now.Year — University Enrollment System</p>
    </footer>
</body>
</html>
