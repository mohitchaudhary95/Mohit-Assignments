@model List<BlobApp.Models.BlobFileModel>

@{
    ViewData["Title"] = "Azure Blob Storage";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Blob Storage Manager</title>
    <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: #f0f2f5;
                color: #333;
            }

            .header {
                background: #1e293b;
                color: white;
                padding: 20px 32px;
                font-size: 1.3rem;
                font-weight: 700;
            }

            .container {
                max-width: 1000px;
                margin: 32px auto;
                padding: 0 20px;
            }

            /* ── ALERTS ── */
            .alert {
                padding: 12px 18px;
                border-radius: 8px;
                margin-bottom: 20px;
                font-size: 0.9rem;
            }
            .alert-success { background: #dcfce7; color: #16a34a; }
            .alert-error   { background: #fee2e2; color: #dc2626; }

            /* ── UPLOAD CARD ── */
            .card {
                background: white;
                border-radius: 12px;
                padding: 24px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.07);
                margin-bottom: 24px;
            }

            .card h2 {
                font-size: 1.1rem;
                color: #1e293b;
                margin-bottom: 16px;
            }

            .upload-area {
                display: flex;
                gap: 12px;
                align-items: center;
                flex-wrap: wrap;
            }

            .upload-area input[type="file"] {
                flex: 1;
                padding: 10px;
                border: 1.5px dashed #cbd5e1;
                border-radius: 8px;
                font-size: 0.9rem;
                background: #f8fafc;
                cursor: pointer;
            }

            .btn {
                padding: 10px 20px;
                border: none;
                border-radius: 8px;
                cursor: pointer;
                font-size: 0.88rem;
                font-weight: 600;
                transition: opacity 0.2s;
                text-decoration: none;
                display: inline-block;
            }
            .btn:hover { opacity: 0.85; }
            .btn-primary  { background: #3b82f6; color: white; }
            .btn-download { background: #16a34a; color: white; }
            .btn-delete   { background: #ef4444; color: white; }
            .btn-sm { padding: 6px 12px; font-size: 0.8rem; }

            .hint {
                color: #94a3b8;
                font-size: 0.8rem;
                margin-top: 8px;
            }

            /* ── FILE TABLE ── */
            .table {
                width: 100%;
                border-collapse: collapse;
                font-size: 0.9rem;
            }
            .table th {
                background: #f8fafc;
                padding: 12px 14px;
                text-align: left;
                color: #64748b;
                font-weight: 600;
                border-bottom: 1px solid #e2e8f0;
            }
            .table td {
                padding: 12px 14px;
                border-bottom: 1px solid #f1f5f9;
            }
            .table tr:hover td { background: #f8fafc; }

            .file-name {
                display: flex;
                align-items: center;
                gap: 8px;
                font-weight: 500;
            }

            .preview-img {
                width: 40px;
                height: 40px;
                object-fit: cover;
                border-radius: 6px;
                border: 1px solid #e2e8f0;
            }

            .actions { display: flex; gap: 8px; }

            .empty-state {
                text-align: center;
                padding: 48px;
                color: #94a3b8;
            }
            .empty-state div { font-size: 3rem; margin-bottom: 12px; }

            .stats {
                display: flex;
                gap: 20px;
                margin-bottom: 24px;
            }
            .stat {
                background: white;
                border-radius: 10px;
                padding: 16px 24px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.07);
                text-align: center;
                flex: 1;
            }
            .stat-num   { font-size: 1.8rem; font-weight: 800; color: #1e293b; }
            .stat-label { color: #64748b; font-size: 0.85rem; }
    </style>
</head>
<body>

    <div class="header">☁️ Azure Blob Storage Manager — mohitstoragecg/data</div>

    <div class="container">

        @* ── ALERTS ── *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">✅ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">❌ @TempData["Error"]</div>
        }

        @* ── STATS ── *@
        <div class="stats">
            <div class="stat">
                <div class="stat-num">@Model.Count</div>
                <div class="stat-label">Total Files</div>
            </div>
            <div class="stat">
                <div class="stat-num">@Model.Count(f => f.IsImage)</div>
                <div class="stat-label">Images</div>
            </div>
            <div class="stat">
                <div class="stat-num">@Model.Count(f => !f.IsImage)</div>
                <div class="stat-label">Documents</div>
            </div>
        </div>

        @* ── UPLOAD ── *@
        <div class="card">
            <h2>📤 Upload File</h2>
            <form asp-action="Upload" asp-controller="Blob"
                  method="post" enctype="multipart/form-data">
                <div class="upload-area">
                    <input type="file" name="file" accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx" required />
                    <button type="submit" class="btn btn-primary">Upload</button>
                </div>
                <p class="hint">Allowed: JPG, PNG, PDF, Word — Max size: 10MB</p>
            </form>
        </div>

        @* ── FILE LIST ── *@
        <div class="card">
            <h2>📋 Files in Container</h2>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div>☁️</div>
                    <p>No files uploaded yet. Upload your first file above!</p>
                </div>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Type</th>
                            <th>Size</th>
                            <th>Last Modified</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model)
                        {
                            <tr>
                                <td>
                                    <div class="file-name">
                                        @if (file.IsImage)
                                        {
                                            <img src="@file.Url" class="preview-img" alt="@file.Name" />
                                        }
                                        else
                                        {
                                            <span style="font-size:1.5rem">@file.FileIcon</span>
                                        }
                                        @file.Name
                                    </div>
                                </td>
                                <td>@file.ContentType</td>
                                <td>@file.SizeFormatted</td>
                                <td>@file.LastModified?.ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td>
                                    <div class="actions">
                                        <a asp-action="Download"
                                               asp-controller="Blob"
                                               asp-route-fileName="@file.Name"
                                               class="btn btn-download btn-sm">
                                            📥 Download
                                        </a>
                                        <form asp-action="Delete"
                                              asp-controller="Blob"
                                              method="post"
                                              onsubmit="return confirm('Delete @file.Name?')">
                                            <input type="hidden" name="fileName" value="@file.Name" />
                                            <button type="submit" class="btn btn-delete btn-sm">
                                                🗑 Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>

</body>
</html>